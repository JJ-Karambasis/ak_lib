{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Win32",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/build/build_win32.bat release env64",
                "problemMatcher": ["$msCompile", "$gcc"]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build Android",
            "type": "shell",
            "windows": {
                "command": "${workspaceFolder}/build/build_android.bat release all",
                "problemMatcher": "$gcc"
            },
            "command": "${workspaceFolder}/build/build_android.sh release all",
            "problemMatcher": "$gcc",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build OSX",
            "type": "shell",
            "osx": {
                "command": "${workspaceFolder}/build/build_osx.sh env32 release",
                "problemMatcher": "$gcc",
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }, 
        {
            "label": "Build Linux",
            "type": "shell",
            "linux": {
                "command": "${workspaceFolder}/build/build_linux.sh release",
                "problemMatcher": "$gcc",
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
} 